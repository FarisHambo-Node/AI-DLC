# Base image for all AI-DLC agents.
# Each agent builds FROM this image and adds only its own entrypoint.

FROM python:3.11-slim AS base

WORKDIR /app

# System dependencies (git needed by code-agent for clone ops)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir -e ".[dev]"

# Copy shared library code
COPY shared/ ./shared/
COPY config/ ./config/
COPY orchestration/ ./orchestration/

# ---- Agent-specific layer ----
# Each agent's Dockerfile inherits from this base:
#
#   FROM ai-dlc-base:latest
#   COPY agents/intake_agent/ ./agents/intake_agent/
#   CMD ["python", "-m", "agents.intake_agent.main"]

# Security: run as non-root
RUN useradd --create-home --shell /bin/bash agent
USER agent

# Health check - each agent exposes /health on port 8000
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1
