# AI-DLC — Environment Variables Template
# =========================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local to version control.
# In production, ALL values come from HashiCorp Vault — not from .env files.

APP_ENV=local    # local | staging | production

# --- Vault (not needed in local mode — values read directly from env) ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (optional fallback) ---
OPENAI_API_KEY=sk-...

# --- Jira ---
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_SERVICE_ACCOUNT_EMAIL=ai-dlc-bot@your-company.com
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=

# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# --- Sentry ---
SENTRY_AUTH_TOKEN=
SENTRY_ORGANIZATION_SLUG=your-org

# --- Redis (state store for LangGraph checkpointer) ---
REDIS_URL=redis://localhost:6379/0

# --- ArgoCD (CI/CD agent) ---
ARGOCD_SERVER=https://argocd.your-company.com
ARGOCD_TOKEN=
